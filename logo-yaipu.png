<!doctype html>
<html lang="th">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=1440" />
  <title>ระบบ ERP — โรงงานชูรสยายปู</title>

  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Thai:wght@300;400;500;600;700&family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&family=Bai+Jamjuree:wght@500;600;700&display=swap" rel="stylesheet" />

  <style>
    :root {
      /* Warm cream / Thai seasoning brand palette */
      --bg: #F6F1E8;
      --surface: #FFFFFF;
      --surface-2: #FBF7EE;
      --surface-sunken: #EFE8DA;
      --border: #E4DBC8;
      --border-strong: #CFC2A8;

      --ink: #221A14;
      --ink-2: #4A3E33;
      --muted: #7A6D5E;
      --muted-2: #A39682;

      --brand: #B6241F;       /* deep crimson — packaging red */
      --brand-ink: #7A1411;
      --brand-soft: #FBE8E5;
      --gold: #C99432;        /* curry gold */
      --gold-soft: #F7EAC8;
      --leaf: #4F7A4A;        /* pandan green */
      --leaf-soft: #E2EDDC;
      --soy: #6B4B1F;         /* soy brown */
      --warn: #C9621E;
      --warn-soft: #F8E3CE;

      --radius: 10px;
      --radius-lg: 14px;
      --shadow-sm: 0 1px 0 rgba(34,26,20,.04), 0 1px 2px rgba(34,26,20,.04);
      --shadow-md: 0 1px 0 rgba(34,26,20,.04), 0 8px 24px -10px rgba(34,26,20,.18);

      --font-sans: "IBM Plex Sans Thai", "IBM Plex Sans", system-ui, sans-serif;
      --font-display: "Bai Jamjuree", "IBM Plex Sans Thai", system-ui, sans-serif;
      --font-mono: "IBM Plex Mono", ui-monospace, monospace;
    }

    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    body {
      background: var(--bg);
      color: var(--ink);
      font-family: var(--font-sans);
      font-size: 14px;
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
    }

    button { font-family: inherit; cursor: pointer; }
    a { color: inherit; }
    input, textarea, select { font-family: inherit; }

    /* ===== App shell ===== */
    .app {
      display: grid;
      grid-template-columns: 240px 1fr;
      min-height: 100vh;
    }

    /* ===== Sidebar ===== */
    .sidebar {
      background: linear-gradient(180deg, #E07A1E 0%, #C75F12 100%);
      color: #FFF1E0;
      padding: 18px 14px 14px;
      display: flex;
      flex-direction: column;
      gap: 4px;
      position: sticky;
      top: 0;
      height: 100vh;
      overflow-y: auto;
      border-right: 1px solid #A84E0E;
    }
    .sidebar::-webkit-scrollbar { width: 7px; }
    .sidebar::-webkit-scrollbar-thumb { background: rgba(0,0,0,.18); border-radius: 99px; }
    .sidebar::-webkit-scrollbar-track { background: transparent; }
    .brand {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 6px 8px 14px;
      background: #E07A1E;
      border-bottom: 1px dashed rgba(255,255,255,.32);
      margin-bottom: 10px;
    }
    .brand-mark {
      width: 38px;
      height: 38px;
      border-radius: 9px;
      background: #B6241F;
      display: grid;
      place-items: center;
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 18px;
      color: #FBE5C9;
      letter-spacing: -0.02em;
      box-shadow: inset 0 -2px 0 rgba(0,0,0,.22), inset 0 1px 0 rgba(255,255,255,.14);
    }
    .brand-name {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 15px;
      color: #FFF8EE;
      line-height: 1.1;
    }
    .brand-sub {
      font-size: 11px;
      color: #FBDCBB;
      letter-spacing: 0.02em;
    }

    .nav-section {
      font-size: 10.5px;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: #FCD9B4;
      padding: 14px 10px 6px;
      font-family: var(--font-display);
      font-weight: 600;
    }
    .nav-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 10px;
      border-radius: 7px;
      color: #FFF1E0;
      font-size: 13.5px;
      cursor: pointer;
      transition: background 80ms;
      border: none;
      background: transparent;
      text-align: left;
      width: 100%;
    }
    .nav-item:hover { background: rgba(255,255,255,.16); color: #FFFBF4; }
    .nav-item.active {
      background: linear-gradient(180deg, rgba(0,0,0,.26) 0%, rgba(0,0,0,.34) 100%);
      color: #FFFBF4;
      box-shadow: inset 0 0 0 1px rgba(255,255,255,.28);
    }
    .nav-item .ico { width: 16px; height: 16px; opacity: .9; flex: 0 0 16px; }
    .nav-item .count {
      margin-left: auto;
      font-size: 10.5px;
      background: rgba(0,0,0,.2);
      color: #FFE9CF;
      padding: 1px 7px;
      border-radius: 99px;
      font-feature-settings: "tnum";
    }
    .nav-item.active .count { background: rgba(0,0,0,.32); color: #FFEAD0; }

    .sidebar-foot {
      margin-top: auto;
      padding: 10px;
      background: #C75F12;
      border-top: 1px dashed rgba(255,255,255,.32);
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .avatar {
      width: 32px; height: 32px; border-radius: 50%;
      background: #B6241F;
      display: grid; place-items: center;
      font-weight: 600; color: #FBE5C9;
      font-size: 12px;
    }
    .user-name { font-size: 12.5px; color: #FFF8EE; line-height: 1.2; }
    .user-role { font-size: 11px; color: #FBDCBB; }

    /* ===== Main area ===== */
    .main { display: flex; flex-direction: column; min-width: 0; }

    .topbar {
      height: 56px;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 0 24px;
      display: flex;
      align-items: center;
      gap: 16px;
      position: sticky;
      top: 0;
      z-index: 10;
    }
    .breadcrumb {
      font-size: 12.5px;
      color: var(--muted);
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .breadcrumb .sep { color: var(--muted-2); }
    .breadcrumb .here { color: var(--ink); font-weight: 500; }

    .search {
      margin-left: auto;
      display: flex;
      align-items: center;
      gap: 8px;
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 6px 10px;
      width: 320px;
      color: var(--muted);
      font-size: 12.5px;
    }
    .search input {
      border: none;
      background: transparent;
      outline: none;
      flex: 1;
      font-size: 13px;
      color: var(--ink);
    }
    .search .kbd {
      font-family: var(--font-mono);
      font-size: 10.5px;
      background: var(--surface);
      border: 1px solid var(--border);
      padding: 1px 6px;
      border-radius: 4px;
      color: var(--muted);
    }
    .icon-btn {
      width: 34px; height: 34px;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: var(--surface);
      display: grid; place-items: center;
      color: var(--ink-2);
      position: relative;
    }
    .icon-btn .dot {
      position: absolute; top: 6px; right: 6px;
      width: 7px; height: 7px; border-radius: 50%;
      background: var(--brand);
      box-shadow: 0 0 0 2px var(--surface);
    }

    /* ===== Page container ===== */
    .page {
      padding: 24px 28px 80px;
      max-width: 1400px;
      width: 100%;
    }

    .page-head {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 24px;
      margin-bottom: 22px;
      flex-wrap: wrap;
    }
    .page-title {
      font-family: var(--font-display);
      font-size: 26px;
      font-weight: 700;
      letter-spacing: -0.01em;
      margin: 0 0 4px;
      color: var(--ink);
    }
    .page-sub { color: var(--muted); font-size: 13px; margin: 0; }

    .page-actions { display: flex; gap: 8px; align-items: center; }

    /* ===== Buttons ===== */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 7px 12px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 500;
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--ink);
      transition: all 80ms;
    }
    .btn:hover { background: var(--surface-2); border-color: var(--border-strong); }
    .btn-primary {
      background: var(--brand);
      border-color: var(--brand-ink);
      color: #FFF6E8;
      box-shadow: inset 0 -1px 0 rgba(0,0,0,.16), inset 0 1px 0 rgba(255,255,255,.12);
    }
    .btn-primary:hover { background: var(--brand-ink); border-color: var(--brand-ink); }
    .btn-ghost { background: transparent; border-color: transparent; color: var(--ink-2); }
    .btn-ghost:hover { background: var(--surface-2); }
    .btn-sm { padding: 4px 9px; font-size: 12px; border-radius: 6px; }

    /* ===== Cards ===== */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-sm);
    }
    .card-head {
      padding: 14px 16px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
    }
    .card-title {
      font-family: var(--font-display);
      font-size: 14px;
      font-weight: 600;
      margin: 0;
      color: var(--ink);
    }
    .card-sub { font-size: 12px; color: var(--muted); }
    .card-body { padding: 16px; }

    /* ===== KPI tiles ===== */
    .kpi-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
    }
    .kpi {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 14px 16px 16px;
      position: relative;
      overflow: hidden;
    }
    .kpi .label {
      font-size: 12px;
      color: var(--muted);
      display: flex; align-items: center; gap: 6px;
    }
    .kpi .value {
      font-family: var(--font-display);
      font-size: 26px;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-top: 4px;
      color: var(--ink);
      font-feature-settings: "tnum";
    }
    .kpi .unit { font-size: 12px; color: var(--muted); font-weight: 500; margin-left: 2px; }
    .kpi .delta {
      margin-top: 8px;
      font-size: 11.5px;
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 2px 7px;
      border-radius: 99px;
    }
    .delta.up { background: var(--leaf-soft); color: #2D5128; }
    .delta.down { background: var(--brand-soft); color: var(--brand-ink); }
    .delta.flat { background: var(--surface-sunken); color: var(--muted); }

    .kpi-spark {
      position: absolute;
      right: 12px; top: 12px;
      opacity: 0.85;
    }

    /* ===== Tables ===== */
    .tbl { width: 100%; border-collapse: collapse; font-size: 13px; }
    .tbl thead th {
      text-align: left;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--muted);
      padding: 10px 14px;
      background: var(--surface-2);
      border-bottom: 1px solid var(--border);
      white-space: nowrap;
    }
    .tbl tbody td {
      padding: 11px 14px;
      border-bottom: 1px solid var(--border);
      vertical-align: middle;
    }
    .tbl tbody tr:last-child td { border-bottom: none; }
    .tbl tbody tr:hover { background: var(--surface-2); }
    .tbl .num { font-feature-settings: "tnum"; text-align: right; font-variant-numeric: tabular-nums; }
    .tbl .code { font-family: var(--font-mono); font-size: 12px; color: var(--ink-2); }

    /* ===== Badges ===== */
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      font-size: 11.5px;
      font-weight: 500;
      padding: 2px 8px;
      border-radius: 99px;
      background: var(--surface-sunken);
      color: var(--ink-2);
      white-space: nowrap;
    }
    .badge .dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: currentColor;
    }
    .b-prod { background: #FCEFD8; color: #7A5414; }
    .b-done { background: var(--leaf-soft); color: #2D5128; }
    .b-wait { background: #E9E1F1; color: #4B3979; }
    .b-warn { background: var(--warn-soft); color: #7A3712; }
    .b-stop { background: var(--brand-soft); color: var(--brand-ink); }
    .b-info { background: #DFE9EF; color: #2B4A5D; }
    .b-neutral { background: var(--surface-sunken); color: var(--ink-2); }

    /* ===== Inventory bars ===== */
    .bar {
      width: 100%;
      height: 6px;
      background: var(--surface-sunken);
      border-radius: 99px;
      overflow: hidden;
      position: relative;
    }
    .bar .fill {
      height: 100%;
      border-radius: 99px;
      background: var(--leaf);
    }
    .bar.warn .fill { background: var(--warn); }
    .bar.danger .fill { background: var(--brand); }

    /* ===== Helpers ===== */
    .row { display: flex; align-items: center; gap: 10px; }
    .col { display: flex; flex-direction: column; gap: 2px; }
    .grow { flex: 1; }
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
    .grid-dash { display: grid; grid-template-columns: 2fr 1fr; gap: 14px; }
    .stack { display: flex; flex-direction: column; gap: 14px; }
    .muted { color: var(--muted); }
    .small { font-size: 12px; }
    .tnum { font-feature-settings: "tnum"; font-variant-numeric: tabular-nums; }

    .swatch {
      width: 28px; height: 28px; border-radius: 6px;
      background: var(--surface-sunken);
      border: 1px solid var(--border);
      display: inline-grid; place-items: center;
      font-size: 14px;
      flex: 0 0 28px;
    }

    /* tabs */
    .tabs {
      display: flex;
      gap: 2px;
      border-bottom: 1px solid var(--border);
      margin-bottom: 14px;
    }
    .tab {
      padding: 8px 12px;
      font-size: 13px;
      color: var(--muted);
      border: none;
      background: transparent;
      border-bottom: 2px solid transparent;
      margin-bottom: -1px;
      font-weight: 500;
    }
    .tab.active {
      color: var(--brand);
      border-bottom-color: var(--brand);
    }
    .tab .count {
      font-size: 11px;
      background: var(--surface-sunken);
      color: var(--muted);
      padding: 1px 7px;
      border-radius: 99px;
      margin-left: 4px;
    }
    .tab.active .count { background: var(--brand-soft); color: var(--brand-ink); }

    /* filter chips */
    .filters {
      display: flex; align-items: center; gap: 8px;
      padding: 10px 14px;
      border-bottom: 1px solid var(--border);
      flex-wrap: wrap;
    }
    .chip {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 4px 9px;
      border-radius: 6px;
      border: 1px solid var(--border);
      background: var(--surface);
      font-size: 12px;
      color: var(--ink-2);
    }
    .chip.active { background: #FBEBE9; border-color: #E9B6B1; color: var(--brand-ink); }

    /* Production batch card */
    .batch-card {
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 12px 14px;
      background: var(--surface);
      display: flex; flex-direction: column; gap: 8px;
    }
    .batch-card.active { border-color: #E9B6B1; box-shadow: 0 0 0 3px #FBEBE9; }

    /* Mini calendar dots */
    .calendar {
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 4px;
      font-size: 11px;
    }
    .cal-day {
      aspect-ratio: 1;
      border-radius: 6px;
      background: var(--surface-2);
      border: 1px solid var(--border);
      padding: 4px 6px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      color: var(--muted);
    }
    .cal-day.has { background: #FBE8E5; border-color: #EFC9C4; color: var(--brand-ink); }
    .cal-day.today { background: var(--ink); color: #FBE5C9; border-color: var(--ink); }
    .cal-day .num { font-feature-settings: "tnum"; font-weight: 600; font-size: 12px; }
    .cal-day .pip {
      align-self: flex-end;
      width: 5px; height: 5px;
      border-radius: 50%;
      background: var(--brand);
    }
    .cal-day.today .pip { background: var(--gold); }

    /* Recipe ingredient row */
    .ing-row {
      display: grid;
      grid-template-columns: 1fr 70px 90px 90px;
      gap: 10px;
      padding: 9px 0;
      border-bottom: 1px dashed var(--border);
      font-size: 13px;
      align-items: center;
    }
    .ing-row:last-child { border-bottom: none; }

    /* Activity feed */
    .feed-item {
      display: grid;
      grid-template-columns: 30px 1fr auto;
      gap: 10px;
      padding: 10px 0;
      border-bottom: 1px dashed var(--border);
      align-items: flex-start;
    }
    .feed-item:last-child { border-bottom: none; }
    .feed-ico {
      width: 28px; height: 28px;
      border-radius: 8px;
      background: var(--surface-sunken);
      display: grid; place-items: center;
      color: var(--ink-2);
    }
    .feed-ico.brand { background: var(--brand-soft); color: var(--brand-ink); }
    .feed-ico.gold { background: var(--gold-soft); color: #6F4E12; }
    .feed-ico.leaf { background: var(--leaf-soft); color: #2D5128; }

    /* legend dot */
    .legend { display: inline-flex; align-items: center; gap: 5px; font-size: 11.5px; color: var(--muted); }
    .legend .lg-dot { width: 9px; height: 9px; border-radius: 2px; }

    /* simple progress with multiple stages */
    .stages { display: flex; gap: 4px; align-items: center; }
    .stage { flex: 1; height: 6px; border-radius: 3px; background: var(--surface-sunken); }
    .stage.done { background: var(--leaf); }
    .stage.active { background: var(--gold); }

    /* table-style cells variations */
    .cell-product {
      display: flex; align-items: center; gap: 10px;
    }
    .cell-product .swatch { font-family: var(--font-display); color: var(--brand-ink); background: var(--gold-soft); border-color: #E7D6A9;}
    .cell-product .name { font-weight: 500; color: var(--ink); }
    .cell-product .sku { font-family: var(--font-mono); font-size: 11px; color: var(--muted); }

    /* tweaks color theme swatch (handled by Tweak) — variables get overridden via inline style on body */

    .alert {
      display: flex; gap: 10px; align-items: flex-start;
      background: var(--warn-soft);
      border: 1px solid #E9C9A8;
      color: #6E3F12;
      padding: 10px 12px;
      border-radius: 10px;
      font-size: 12.5px;
    }
    .alert.danger { background: var(--brand-soft); border-color: #E9B6B1; color: var(--brand-ink); }
    .alert .ico { flex: 0 0 18px; margin-top: 1px; }

    /* Print — show only the sales-order form */
    @media print {
      body * { visibility: hidden; }
      #so-print-area, #so-print-area * { visibility: visible; }
      #so-print-area {
        position: absolute; left: 0; top: 0;
        width: 100% !important; min-height: auto !important;
        margin: 0 !important; padding: 14mm 12mm !important;
        box-shadow: none !important;
      }
      .no-print { display: none !important; }
      @page { size: A4; margin: 0; }
    }
  </style>

  <!-- React (development builds for Babel compatibility) -->
  <script src="https://unpkg.com/react@18.3.1/umd/react.development.js" integrity="sha384-hD6/rw4ppMLGNu3tX5cjIb+uRZ7UkRJ6BPkLpg4hAu/6onKUg4lLsHAs9EBPT82L" crossorigin="anonymous"></script>
  <script src="https://unpkg.com/react-dom@18.3.1/umd/react-dom.development.js" integrity="sha384-u6aeetuaXnQ38mYT8rp6sbXaQe3NL9t+IBXmnYxwkUI2Hw4bsp2Wvmx4yRQF1uAm" crossorigin="anonymous"></script>
  <script src="https://unpkg.com/@babel/standalone@7.29.0/babel.min.js" integrity="sha384-m08KidiNqLdpJqLq95G/LEi8Qvjl/xUYll3QILypMoQ65QorJ9Lvtp2RXYGBFj1y" crossorigin="anonymous"></script>
</head>
<body>
  <template id="__bundler_thumbnail">
    <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
      <rect width="100" height="100" fill="#B6241F"/>
      <rect x="30" y="30" width="40" height="40" rx="8" fill="#F7EAC8"/>
      <text x="50" y="58" font-size="26" font-weight="700" text-anchor="middle" fill="#B6241F" font-family="sans-serif">ปู</text>
    </svg>
  </template>

  <div id="root"></div>

  <!-- Cloud sync (plain JS, must run before app modules) -->
  <script src="supabase-config.js?v=1"></script>
  <script src="auth-gate.js?v=1"></script>
  <script src="cloud-sync.js?v=5"></script>

  <!-- Load all JSX modules -->
  <script type="text/babel" src="utils-cache.jsx?v=1"></script>
  <script type="text/babel" src="data.jsx?v=3"></script>
  <script type="text/babel" src="data-customers.jsx?v=1"></script>
  <script type="text/babel" src="components.jsx?v=4"></script>
  <script type="text/babel" src="components-sales-pickers.jsx?v=1"></script>
